---
import '../styles/global.css';

type JsonLdDocument = Record<string, unknown>;

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  robots?: string;
  openGraphType?: 'article' | 'website';
  openGraphImagePath?: string;
  structuredData?: JsonLdDocument | JsonLdDocument[];
}

const {
  title,
  description = 'BoltFFI - Fast, safe Rust FFI binding generator for Swift, Kotlin, Java, Ruby, WASM, Python, and C#',
  canonicalUrl,
  robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
  openGraphType = 'website',
  openGraphImagePath = '/logo.png',
  structuredData,
} = Astro.props;
const siteUrl = Astro.site ?? new URL('https://boltffi.dev');
const pageTitle = `${title} | BoltFFI`;
const rawCanonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const resolvedCanonicalUrl = rawCanonical.endsWith('/') && rawCanonical !== siteUrl.toString() + '/'
  ? rawCanonical.slice(0, -1)
  : rawCanonical;
const resolvedOpenGraphImageUrl = new URL(openGraphImagePath, siteUrl).toString();
const structuredDataDocuments = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <link rel="canonical" href={resolvedCanonicalUrl} />
    <meta property="og:site_name" content="BoltFFI" />
    <meta property="og:type" content={openGraphType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonicalUrl} />
    <meta property="og:image" content={resolvedOpenGraphImageUrl} />
    <meta property="og:image:alt" content="BoltFFI logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOpenGraphImageUrl} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <title>{pageTitle}</title>
    {structuredDataDocuments.map((document) => (
      <script type="application/ld+json" set:html={JSON.stringify(document)} />
    ))}
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <slot />
    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
  </body>
</html>
