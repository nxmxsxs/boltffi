---
import CodeComparison from './CodeComparison';

interface Props {
  rust: string;
  swift: string;
  kotlin: string;
  typescript?: string;
  title?: string;
}

const { rust, swift, kotlin, typescript, title } = Astro.props;
---

<CodeComparison
  rust={rust}
  swift={swift}
  kotlin={kotlin}
  typescript={typescript}
  title={title}
  client:load
/>
