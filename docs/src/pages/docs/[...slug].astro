---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

type JsonLdDocument = Record<string, unknown>;

const PAGE_ORDER = [
  'overview',
  'getting-started',
  'installation',
  'quick-start',
  'types',
  'records',
  'classes',
  'functions',
  'async',
  'callbacks',
  'streaming',
  'errors',
  'custom-types',
  'packaging',
  'configuration',
  'experimental',
  'async-internals',
  'tutorial',
];

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allDocs = await getCollection('docs');
const currentIndex = PAGE_ORDER.indexOf(entry.id);
const prevSlug = currentIndex > 0 ? PAGE_ORDER[currentIndex - 1] : null;
const nextSlug = currentIndex < PAGE_ORDER.length - 1 ? PAGE_ORDER[currentIndex + 1] : null;
const prevEntry = prevSlug ? allDocs.find(d => d.id === prevSlug) : null;
const nextEntry = nextSlug ? allDocs.find(d => d.id === nextSlug) : null;
const activeSection = entry.id;
const title = entry.data.title || entry.id.charAt(0).toUpperCase() + entry.id.slice(1).replace(/-/g, ' ');
const description = entry.data.description;
const siteUrl = Astro.site ?? new URL('https://boltffi.dev');
const canonicalUrl = new URL(`/docs/${entry.id}`, siteUrl).toString();
const docsIndexUrl = new URL('/docs/overview', siteUrl).toString();
const breadcrumbStructuredData: JsonLdDocument = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Docs',
      item: docsIndexUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: title,
      item: canonicalUrl,
    },
  ],
};
const pageStructuredData: JsonLdDocument = entry.id === 'overview'
  ? {
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'BoltFFI',
      applicationCategory: 'DeveloperApplication',
      url: canonicalUrl,
      description,
      operatingSystem: 'macOS, Linux, Windows',
      softwareHelp: {
        '@type': 'CreativeWork',
        url: docsIndexUrl,
      },
      programmingLanguage: 'Rust',
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'TechArticle',
      headline: title,
      description,
      url: canonicalUrl,
      inLanguage: 'en',
      mainEntityOfPage: canonicalUrl,
      author: {
        '@type': 'Organization',
        name: 'BoltFFI',
      },
      publisher: {
        '@type': 'Organization',
        name: 'BoltFFI',
      },
      isPartOf: {
        '@type': 'CreativeWork',
        name: 'BoltFFI Documentation',
        url: docsIndexUrl,
      },
    };
const structuredData: JsonLdDocument[] = [breadcrumbStructuredData, pageStructuredData];
---

<DocsLayout
  title={title}
  description={description}
  activeSection={activeSection}
  canonicalUrl={canonicalUrl}
  openGraphType={entry.id === 'overview' ? 'website' : 'article'}
  structuredData={structuredData}
>
  <Content />
  {(prevEntry || nextEntry) && (
    <nav class="mt-16 pt-8 border-t border-border flex justify-between items-center not-prose">
      {prevEntry ? (
        <a href={`/docs/${prevEntry.id}`} class="group flex flex-col items-start gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors">
          <span class="text-xs uppercase tracking-wider">Previous</span>
          <span class="font-medium text-foreground group-hover:text-primary transition-colors">{prevEntry.data.title}</span>
        </a>
      ) : <div />}
      {nextEntry ? (
        <a href={`/docs/${nextEntry.id}`} class="group flex flex-col items-end gap-1 text-sm text-muted-foreground hover:text-foreground transition-colors">
          <span class="text-xs uppercase tracking-wider">Next</span>
          <span class="font-medium text-foreground group-hover:text-primary transition-colors">{nextEntry.data.title}</span>
        </a>
      ) : <div />}
    </nav>
  )}
</DocsLayout>
