using System;
using System.Text;

namespace Demo
{
    public readonly record struct Person(
        string Name,
        uint Age
    )
    {
        internal static Person Decode(WireReader reader) =>
            new Person(
                reader.ReadString(),
                reader.ReadU32()
            );

        internal int WireEncodedSize() =>
            (4 + Encoding.UTF8.GetByteCount(this.Name)) +
            4;

        internal void WireEncodeTo(WireWriter wire)
