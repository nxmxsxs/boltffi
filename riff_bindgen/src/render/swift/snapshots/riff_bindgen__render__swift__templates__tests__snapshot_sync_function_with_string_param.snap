---
source: riff_bindgen/src/render/swift/templates.rs
expression: "render_function(&func, \"riff\")"
---
public func greet(name: String) -> String {
    return name.withCString { namePtr in
        let buf = riff_greet(UnsafeRawPointer(namePtr).assumingMemoryBound(to: UInt8.self), UInt(name.utf8.count))
        defer { riff_free_buf_u8(buf) }
        return riffDecodeOwnedBuf(buf.ptr, Int(buf.len)) { reader in reader.readString() }
    }
}
