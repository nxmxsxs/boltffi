public struct Config: Hashable, Equatable, Sendable {
    public var timeout: Double
    public var retries: Int32

    public init(timeout: Double = 30.0, retries: Int32 = 3) {
        self.timeout = timeout
        self.retries = retries
    }

    @inlinable static func decode(wireBuffer wire: WireBuffer, at offset: Int) -> (value: Config, size: Int) {
        return (Config(timeout: wire.readF64(at: offset), retries: wire.readI32(at: offset + 8)), 12)
    }
}

extension Config: WireEncodable {
    @usableFromInline static var isBlittable: Bool { true }
    @inlinable func wireEncodedSize() -> Int { 12 }
    @inlinable func wireEncodeTo(_ data: inout Data) {
        var copy = self
        Swift.withUnsafeBytes(of: &copy) { data.append(contentsOf: $0) }
    }
    @inlinable func wireEncodeToBytes(_ bytes: inout [UInt8]) {
        var copy = self
        Swift.withUnsafeBytes(of: &copy) { bytes.append(contentsOf: $0) }
    }
}
