public struct Config: Hashable, Equatable, Sendable {
    public var timeout: Double
    public var retries: Int32

    public init(timeout: Double = 30.0, retries: Int32 = 3) {
        self.timeout = timeout
        self.retries = retries
    }

}

extension Config: WireCodable {
    @inlinable static func decode(from reader: inout WireReader) -> Config { reader.readBlittable() }
    @inlinable func encode(to writer: inout WireWriter) { writer.writeBlittable(self) }
}
