---
source: riff_bindgen/src/render/swift/templates.rs
expression: render_record(&record)
---
public struct Team: Hashable, Equatable, Sendable {
    public var name: String
    public var members: [String]

    public init(name: String, members: [String]) {
        self.name = name
        self.members = members
    }

}

extension Team: WireCodable {
    @inlinable static func decode(from reader: inout WireReader) -> Team {
        Team(name: reader.readString(), members: reader.readArray { reader in reader.readString() })
    }
    @inlinable func encode(to writer: inout WireWriter) {
        writer.writeString(name)
        writer.writeArray(members) { writer, item in writer.writeString(item) }
    }
}
