---
source: riff_bindgen/src/render/swift/templates.rs
expression: render_record(&record)
---
public struct User: Hashable, Equatable, Sendable {
    public var id: Int64
    public var name: String

    public init(id: Int64, name: String) {
        self.id = id
        self.name = name
    }

}

extension User: WireCodable {
    @inlinable static func decode(from reader: inout WireReader) -> User {
        User(id: reader.readI64(), name: reader.readString())
    }
    @inlinable func encode(to writer: inout WireWriter) {
        writer.writeI64(id)
        writer.writeString(name)
    }
}
