public struct Padded: Hashable, Equatable, Sendable {
    public var a: UInt8
    public var b: UInt32
    public var c: UInt8

    public init(a: UInt8, b: UInt32, c: UInt8) {
        self.a = a
        self.b = b
        self.c = c
    }

}

extension Padded: WireCodable {
    @inlinable static func decode(from reader: inout WireReader) -> Padded { reader.readBlittable() }
    @inlinable func encode(to writer: inout WireWriter) { writer.writeBlittable(self) }
}
