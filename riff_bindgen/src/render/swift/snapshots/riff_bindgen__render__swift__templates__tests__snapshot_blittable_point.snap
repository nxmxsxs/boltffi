public struct Point: Hashable, Equatable, Sendable {
    public var x: Double
    public var y: Double

    public init(x: Double, y: Double) {
        self.x = x
        self.y = y
    }

    @inlinable static func decode(wireBuffer wire: WireBuffer, at offset: Int) -> (value: Point, size: Int) {
        return (Point(x: wire.readF64(at: offset), y: wire.readF64(at: offset + 8)), 16)
    }
}

extension Point: WireEncodable {
    @usableFromInline static var isBlittable: Bool { true }
    @inlinable func wireEncodedSize() -> Int { 16 }
    @inlinable func wireEncodeTo(_ data: inout Data) {
        var copy = self
        Swift.withUnsafeBytes(of: &copy) { data.append(contentsOf: $0) }
    }
    @inlinable func wireEncodeToBytes(_ bytes: inout [UInt8]) {
        var copy = self
        Swift.withUnsafeBytes(of: &copy) { bytes.append(contentsOf: $0) }
    }
}
