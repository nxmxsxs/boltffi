/// A physical location with coordinates.
public struct Location: Hashable, Equatable, Sendable {
    /// Unique identifier for this location.
    public var id: Int64
    /// Latitude in decimal degrees.
    public var lat: Double

    public init(id: Int64, lat: Double) {
        self.id = id
        self.lat = lat
    }

}

extension Location: WireCodable {
    @inlinable static func decode(from reader: inout WireReader) -> Location { reader.readBlittable() }
    @inlinable func encode(to writer: inout WireWriter) { writer.writeBlittable(self) }
}
