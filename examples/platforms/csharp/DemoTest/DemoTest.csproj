<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>BoltFFI.Demo.Tests</RootNamespace>
    <AssemblyName>DemoTest</AssemblyName>
    <Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Generated BoltFFI wrappers use `fixed` to pin managed memory
         for zero-copy P/Invoke calls. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\dist\*.cs" Link="Generated\%(Filename)%(Extension)" />
  </ItemGroup>

</Project>
